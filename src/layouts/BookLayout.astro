---
import type { BookNode, GlossarySymbol } from '../lib/xml/docbook-ast.js';
import '../styles/global.css';

interface Props {
  book: BookNode;
  glossary: GlossarySymbol[];
}

const { book, glossary } = Astro.props;

const categoryOrder = ['energy', 'inertia', 'dynamics', 'system', 'coordinates', 'kinematics', 'forces', 'conservation', 'variational'];
const sortedGlossary = [...glossary].sort((a, b) => {
  const ia = categoryOrder.indexOf(a.category);
  const ib = categoryOrder.indexOf(b.category);
  if (ia !== ib) return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
  return a.name.localeCompare(b.name);
});
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{book.title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <header class="book-header">
      <h1>{book.title}</h1>
      <p class="subtitle">{book.subtitle}</p>
    </header>

    <div class="layout-wrapper">
      <!-- Sidebar TOC -->
      <nav class="sidebar" id="sidebar" aria-label="Inhaltsverzeichnis">
        <button class="sidebar-glossary-btn" id="open-glossary">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h4a2 2 0 0 1 2 2v8a1.5 1.5 0 0 0-1.5-1.5H2V3z"/><path d="M14 3h-4a2 2 0 0 0-2 2v8a1.5 1.5 0 0 1 1.5-1.5H14V3z"/></svg>
          Symbolverzeichnis
        </button>

        <h2 class="toc-header" id="toc-toggle">
          Inhaltsverzeichnis
          <span class="toc-chevron">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 2 7 5 3 8"/></svg>
          </span>
        </h2>

        <div class="toc-body" id="toc-body">
          <ol class="toc-list">
            {book.chapters.map((ch) => (
              <li class="toc-chapter-item">
                <button class="chapter-toggle" aria-label="Abschnitte ein-/ausblenden">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 2 7 5 3 8"/></svg>
                </button>
                <a class="toc-chapter-link" href={`#${ch.id}`}>{ch.number}. {ch.title}</a>
                {ch.sections.length > 0 && (
                  <ol class="toc-section-list">
                    {ch.sections.map((sec) => (
                      <li>
                        <a class="toc-section-link" href={`#${sec.id}`}>
                          {sec.title.map(n => n.type === 'text' ? n.content : n.type === 'inline-math' ? '' : '').join('')}
                        </a>
                      </li>
                    ))}
                  </ol>
                )}
              </li>
            ))}
            <li class="toc-chapter-item" style="margin-top: 0.5rem;">
              <a class="toc-section-link" href="#glossary-appendix" style="font-style: italic;">
                Symbolverzeichnis
              </a>
            </li>
          </ol>
        </div>
      </nav>

      <!-- Main Content -->
      <main class="main-content">
        <slot />

        <!-- Glossary Appendix -->
        <section class="glossary-appendix" id="glossary-appendix">
          <h2 class="glossary-appendix-heading">Symbolverzeichnis</h2>
          <table class="notation-table" id="appendix-notation-table">
            <thead>
              <tr>
                <th>Symbol</th>
                <th>Name</th>
                <th class="desc-cell">Beschreibung</th>
                <th>Einheit</th>
              </tr>
            </thead>
            <tbody>
              {sortedGlossary.map((sym) => (
                <tr data-symbol-id={sym.id} data-chapters={sym.chapters.join(' ')}>
                  <td class="symbol-cell"><Fragment set:html={sym.latexHtml} /></td>
                  <td>{sym.name}</td>
                  <td class="desc-cell">{sym.description}</td>
                  <td class="unit-cell">{sym.unit || '\u2014'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      </main>
    </div>

    <!-- Glossary Slide-Over Panel -->
    <div class="glossary-backdrop" id="glossary-backdrop"></div>
    <div class="glossary-slideover" id="glossary-panel">
      <div class="slideover-header">
        <h3>Symbolverzeichnis</h3>
        <button class="slideover-close" id="close-glossary" aria-label="Schließen">&times;</button>
      </div>
      <div class="slideover-body">
        <table class="notation-table" id="slideover-notation-table">
          <thead>
            <tr>
              <th>Symbol</th>
              <th>Name</th>
              <th class="desc-cell">Beschreibung</th>
              <th>Einheit</th>
            </tr>
          </thead>
          <tbody>
            {sortedGlossary.map((sym) => (
              <tr data-symbol-id={sym.id} data-chapters={sym.chapters.join(' ')}>
                <td class="symbol-cell"><Fragment set:html={sym.latexHtml} /></td>
                <td>{sym.name}</td>
                <td class="desc-cell">{sym.description}</td>
                <td class="unit-cell">{sym.unit || '\u2014'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mobile Nav Toggle -->
    <button class="mobile-nav-toggle" id="mobile-nav-toggle" aria-label="Navigation öffnen">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="mobile-nav-backdrop" id="mobile-nav-backdrop"></div>

    <!-- Embed glossary data for client-side scripts -->
    <script type="application/json" id="glossary-data" set:html={JSON.stringify(sortedGlossary)} />

    <script>
      // ─── TOC Toggle ─────────────────────────────────────────────
      const tocToggle = document.getElementById('toc-toggle');
      const tocBody = document.getElementById('toc-body');
      tocToggle?.addEventListener('click', () => {
        tocToggle.classList.toggle('collapsed');
        tocBody?.classList.toggle('collapsed');
      });

      // ─── Chapter Section Toggles ────────────────────────────────
      document.querySelectorAll('.chapter-toggle').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          btn.parentElement?.classList.toggle('sections-collapsed');
        });
      });

      // ─── Glossary Panel ─────────────────────────────────────────
      const panel = document.getElementById('glossary-panel');
      const backdrop = document.getElementById('glossary-backdrop');

      function openGlossary() {
        panel?.classList.add('open');
        backdrop?.classList.add('visible');
        updateGlossaryHighlight();
      }
      function closeGlossary() {
        panel?.classList.remove('open');
        backdrop?.classList.remove('visible');
      }

      document.getElementById('open-glossary')?.addEventListener('click', openGlossary);
      document.getElementById('close-glossary')?.addEventListener('click', closeGlossary);
      backdrop?.addEventListener('click', closeGlossary);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeGlossary();
      });

      // ─── Mobile Navigation ──────────────────────────────────────
      const sidebar = document.getElementById('sidebar');
      const mobileToggle = document.getElementById('mobile-nav-toggle');
      const mobileBackdrop = document.getElementById('mobile-nav-backdrop');

      function openMobileNav() {
        sidebar?.classList.add('mobile-open');
        mobileBackdrop?.classList.add('visible');
        mobileBackdrop!.style.display = 'block';
      }
      function closeMobileNav() {
        sidebar?.classList.remove('mobile-open');
        mobileBackdrop?.classList.remove('visible');
        setTimeout(() => { if (mobileBackdrop) mobileBackdrop.style.display = 'none'; }, 300);
      }

      mobileToggle?.addEventListener('click', openMobileNav);
      mobileBackdrop?.addEventListener('click', closeMobileNav);

      // Close mobile nav on link click
      sidebar?.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', () => {
          if (window.innerWidth < 900) closeMobileNav();
        });
      });

      // ─── Scroll Spy: TOC Active State ───────────────────────────
      const sections = document.querySelectorAll('article.chapter[id], section[id]');
      let currentActiveId = '';

      const scrollObserver = new IntersectionObserver(
        (entries) => {
          // Find the entry closest to the top of the viewport
          let best: IntersectionObserverEntry | null = null;
          let bestTop = Infinity;
          for (const entry of entries) {
            if (entry.isIntersecting) {
              const top = Math.abs(entry.boundingClientRect.top);
              if (top < bestTop) {
                bestTop = top;
                best = entry;
              }
            }
          }
          if (best) {
            const id = best.target.id;
            if (id !== currentActiveId) {
              currentActiveId = id;
              // Update TOC
              document.querySelectorAll('.toc-chapter-link, .toc-section-link').forEach((a) => {
                a.classList.toggle('active', a.getAttribute('href') === `#${id}`);
              });
              // Update glossary if open
              if (panel?.classList.contains('open')) {
                updateGlossaryHighlight();
              }
            }
          }
        },
        { rootMargin: '-10% 0px -70% 0px', threshold: [0, 0.1] }
      );
      sections.forEach((s) => scrollObserver.observe(s));

      // ─── Glossary Context Highlighting ──────────────────────────
      function updateGlossaryHighlight() {
        const table = document.getElementById('slideover-notation-table');
        if (!table) return;

        const section = findVisibleSection();
        const rows = table.querySelectorAll('tbody tr');
        const tbody = table.querySelector('tbody');
        if (!tbody) return;

        if (!section) {
          rows.forEach((tr) => tr.classList.remove('symbol-relevant', 'symbol-dimmed'));
          return;
        }

        // Find chapter this section belongs to
        const chapter = section.closest('article.chapter');
        const chapterId = chapter?.id || '';

        // Get LaTeX content in visible section
        const latexEls = section.querySelectorAll('[data-latex]');
        const texContent = Array.from(latexEls).map((el) => el.getAttribute('data-latex') || '').join(' ');

        // Load glossary data
        const glossaryData: any[] = JSON.parse(
          document.getElementById('glossary-data')?.textContent || '[]'
        );

        const relevantIds = new Set<string>();
        for (const sym of glossaryData) {
          // Chapter match
          if (sym.chapters.length > 0 && sym.chapters.includes(chapterId)) {
            relevantIds.add(sym.id);
            continue;
          }
          // LaTeX match
          if (sym.latex.length === 1) {
            const re = new RegExp(`(?<![a-zA-Z\\\\])${sym.latex.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}(?![a-zA-Z])`);
            if (re.test(texContent)) relevantIds.add(sym.id);
          } else if (texContent.includes(sym.latex)) {
            relevantIds.add(sym.id);
          }
        }

        const relevantRows: Element[] = [];
        const otherRows: Element[] = [];

        rows.forEach((tr) => {
          const symId = tr.getAttribute('data-symbol-id') || '';
          tr.classList.remove('symbol-relevant', 'symbol-dimmed');
          if (relevantIds.has(symId)) {
            tr.classList.add('symbol-relevant');
            relevantRows.push(tr);
          } else {
            tr.classList.add('symbol-dimmed');
            otherRows.push(tr);
          }
        });

        // Reorder: relevant first
        relevantRows.forEach((tr) => tbody.appendChild(tr));
        otherRows.forEach((tr) => tbody.appendChild(tr));
      }

      function findVisibleSection(): Element | null {
        const secs = document.querySelectorAll('section[id]');
        let best: Element | null = null;
        let bestScore = -Infinity;
        const mid = window.innerHeight / 2;

        for (const s of secs) {
          const rect = s.getBoundingClientRect();
          if (rect.bottom > 0 && rect.top < window.innerHeight) {
            const score = -Math.abs(rect.top - mid);
            if (score > bestScore) {
              bestScore = score;
              best = s;
            }
          }
        }
        return best;
      }

      // Update glossary on scroll (debounced)
      let rafId = 0;
      window.addEventListener('scroll', () => {
        cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          if (panel?.classList.contains('open')) updateGlossaryHighlight();
        });
      }, { passive: true });

      // ─── Copy-to-Clipboard ────────────────────────────────────
      const CLIPBOARD_SVG = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="8" height="10" rx="1"/><path d="M3 5v7a1 1 0 0 0 1 1h7"/></svg>';
      const CHECK_SVG = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 8 6.5 11.5 13 5"/></svg>';

      function addCopyBtn(heading: Element, scope: 'chapter' | 'section') {
        const btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.innerHTML = CLIPBOARD_SVG;
        btn.title = scope === 'chapter' ? 'Kapitel kopieren' : 'Abschnitt kopieren';
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const container = scope === 'chapter'
            ? heading.closest('article.chapter')
            : heading.closest('section');
          if (!container) return;
          const md = extractMarkdown(container, scope);
          navigator.clipboard.writeText(md).then(() => {
            btn.innerHTML = CHECK_SVG;
            btn.classList.add('success');
            showToast(scope === 'chapter' ? 'Kapitel kopiert' : 'Abschnitt kopiert');
            setTimeout(() => { btn.innerHTML = CLIPBOARD_SVG; btn.classList.remove('success'); }, 1500);
          });
        });
        heading.appendChild(btn);
      }

      document.querySelectorAll('.chapter-heading').forEach((h) => addCopyBtn(h, 'chapter'));
      document.querySelectorAll('.section-heading').forEach((h) => addCopyBtn(h, 'section'));

      function extractMarkdown(el: Element, level: string): string {
        let md = '';
        const walk = (node: Element, depth: number) => {
          for (const child of node.children) {
            if (child.matches('.chapter-heading')) {
              md += `# ${cleanText(child)}\n\n`;
            } else if (child.matches('.section-heading')) {
              md += `\n## ${cleanText(child)}\n\n`;
            } else if (child.matches('.subsection-heading')) {
              md += `\n### ${cleanText(child)}\n\n`;
            } else if (child.matches('p')) {
              md += extractInline(child) + '\n\n';
            } else if (child.matches('.math-display')) {
              const latex = child.getAttribute('data-latex') || '';
              md += `\n$$${stripDlm(latex)}$$\n\n`;
            } else if (child.matches('.equation-wrapper')) {
              const eq = child.querySelector('.equation-content');
              const num = child.querySelector('.equation-number');
              const latex = eq?.getAttribute('data-latex') || '';
              md += `\n$$${stripDlm(latex)}$$${num ? '  ' + num.textContent?.trim() : ''}\n\n`;
            } else if (child.matches('.formalpara')) {
              const title = child.querySelector('.formalpara-title');
              if (title) md += `**${title.textContent?.trim()}**\n\n`;
              const body = child.querySelector('.formalpara-body');
              if (body) walk(body, depth + 1);
            } else if (child.matches('.example-block')) {
              const title = child.querySelector('.example-title');
              if (title) md += `**${title.textContent?.trim()}**\n\n`;
              const body = child.querySelector('.example-body');
              if (body) walk(body, depth + 1);
            } else if (child.matches('.section-block, .subsection-block')) {
              walk(child, depth + 1);
            }
          }
        };
        walk(el, 0);

        // Append glossary
        md += '\n---\n\n## Symbolverzeichnis\n\n';
        md += '| Symbol | Name | Beschreibung | Einheit |\n';
        md += '|--------|------|--------------|--------|\n';
        const glossaryData: any[] = JSON.parse(document.getElementById('glossary-data')?.textContent || '[]');
        for (const sym of glossaryData) {
          md += `| $${sym.latex}$ | ${sym.name} | ${sym.description} | ${sym.unit || '—'} |\n`;
        }
        return md;
      }

      function cleanText(el: Element): string {
        const clone = el.cloneNode(true) as Element;
        clone.querySelectorAll('.copy-btn, .chapter-number').forEach((b) => b.remove());
        return (clone.textContent || '').trim();
      }

      function extractInline(el: Element): string {
        let result = '';
        el.childNodes.forEach((node) => {
          if (node.nodeType === 3) result += node.textContent;
          else if (node.nodeType === 1) {
            const e = node as Element;
            if (e.matches('.math-inline')) {
              result += e.getAttribute('data-latex') || e.textContent;
            } else if (e.matches('strong')) {
              result += `**${e.textContent}**`;
            } else if (e.matches('em')) {
              result += `*${e.textContent}*`;
            } else result += e.textContent;
          }
        });
        return result.trim();
      }

      function stripDlm(s: string): string {
        return s.replace(/^\s*\\\[\s*/, '').replace(/\s*\\\]\s*$/, '').trim();
      }

      function showToast(message: string) {
        document.getElementById('copy-toast')?.remove();
        const toast = document.createElement('div');
        toast.id = 'copy-toast';
        toast.className = 'toast';
        toast.textContent = message;
        document.body.appendChild(toast);
        requestAnimationFrame(() => toast.classList.add('visible'));
        setTimeout(() => {
          toast.classList.remove('visible');
          setTimeout(() => toast.remove(), 250);
        }, 2000);
      }
    </script>
  </body>
</html>
