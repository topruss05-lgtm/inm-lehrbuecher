---
import type { ContentNode, InlineNode } from '../lib/xml/docbook-ast.js';
import type { ResolvedXref } from '../lib/xml/xref-resolver.js';

interface Props {
  nodes: ContentNode[];
  xrefMap?: Map<string, ResolvedXref>;
}

const { nodes, xrefMap } = Astro.props;
const base = import.meta.env.BASE_URL;

function renderInlineNode(n: InlineNode): string {
  if (n.type === 'text') return n.content;
  if (n.type === 'inline-math') return `<span class="math-inline" data-latex="${escAttr(n.latex)}">${n.html}</span>`;
  if (n.type === 'xref') {
    const resolved = xrefMap?.get(n.linkend);
    if (resolved) return `<a href="${escAttr(resolved.url)}" class="xref-link">${esc(resolved.label)}</a>`;
    return `<span class="xref-unresolved" title="Unresolved: ${escAttr(n.linkend)}">[?]</span>`;
  }
  if (n.type === 'emphasis') {
    const inner = n.children.map(renderInlineNode).join('');
    if (n.role === 'bold') return `<strong>${inner}</strong>`;
    if (n.role === 'underline') return `<span class="text-underline">${inner}</span>`;
    if (n.role === 'color-cyan') return `<span class="text-color-cyan">${inner}</span>`;
    return `<em>${inner}</em>`;
  }
  return '';
}

function esc(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function escAttr(s: string): string {
  return esc(s).replace(/"/g, '&quot;');
}
---

{nodes.map((node) => {
  if (node.type === 'para') {
    const html = node.children.map(renderInlineNode).join('');
    return <p class={node.role ? `para-${node.role}` : undefined}><Fragment set:html={html} /></p>;
  }

  if (node.type === 'display-math') {
    return <div class="math-display" data-latex={node.latex} data-pagefind-index-attrs="data-latex"><Fragment set:html={node.html} /></div>;
  }

  if (node.type === 'numbered-equation') {
    return (
      <div class="equation-wrapper" id={node.id} data-pagefind-weight="3">
        {node.title && <span class="equation-title" data-pagefind-meta={`title:${node.title}`}>{node.title}</span>}
        <div class="equation-content" data-latex={node.latex} data-pagefind-index-attrs="data-latex">
          <Fragment set:html={node.html} />
        </div>
        <span class="equation-number">({node.number})</span>
      </div>
    );
  }

  if (node.type === 'formalpara') {
    const fpWeight = (node.role === 'definition' || node.role === 'theorem') ? '5' : '2';
    const fpFilter = node.role === 'definition' ? 'type:Definition' : node.role === 'theorem' ? 'type:Satz' : undefined;
    const titleHtml = node.title.map(renderInlineNode).join('');

    if (node.collapsible || node.role === 'derivation') {
      return (
        <details class={`formalpara fp-${node.role} fp-collapsible`} id={node.id || undefined} data-pagefind-weight={fpWeight}>
          <summary class="formalpara-title collapsible-summary">
            <span class="collapsible-chevron" aria-hidden="true"></span>
            <Fragment set:html={titleHtml} />
          </summary>
          <div class="formalpara-body">
            <Astro.self nodes={node.body} xrefMap={xrefMap} />
          </div>
        </details>
      );
    }

    return (
      <div class={`formalpara fp-${node.role}`} id={node.id || undefined} data-pagefind-weight={fpWeight} data-pagefind-filter={fpFilter}>
        <p class="formalpara-title"><Fragment set:html={titleHtml} /></p>
        <div class="formalpara-body">
          <Astro.self nodes={node.body} xrefMap={xrefMap} />
        </div>
      </div>
    );
  }

  if (node.type === 'example') {
    return (
      <div class="example-block" id={node.id || undefined}>
        <p class="example-title">{node.title}</p>
        <div class="example-body">
          <Astro.self nodes={node.body} xrefMap={xrefMap} />
        </div>
      </div>
    );
  }

  if (node.type === 'figure') {
    return (
      <figure class="figure-block" id={node.id || undefined}>
        {node.imageUrl ? (
          <img src={`${base}${node.imageUrl}`} alt={node.altText} class="figure-image" />
        ) : (
          <div class="figure-placeholder">
            <p class="figure-description">{node.altText}</p>
          </div>
        )}
        <figcaption class="figure-caption">
          <span class="figure-caption-number">Abb. {node.number}: </span>
          {node.title}
        </figcaption>
      </figure>
    );
  }

  if (node.type === 'table') {
    return (
      <div class="table-wrapper" id={node.id || undefined}>
        {node.title && <p class="table-caption">{node.title}</p>}
        <table class="content-table">
          {node.headers.length > 0 && (
            <thead>
              <tr>
                {node.headers.map((cell: InlineNode[]) => {
                  const cellHtml = cell.map(renderInlineNode).join('');
                  return <th><Fragment set:html={cellHtml} /></th>;
                })}
              </tr>
            </thead>
          )}
          {node.rows.length > 0 && (
            <tbody>
              {(() => {
                const colCount = node.headers.length || 3;
                const rowGroups: InlineNode[][][] = [];
                for (let i = 0; i < node.rows.length; i += colCount) {
                  rowGroups.push(node.rows.slice(i, i + colCount));
                }
                return rowGroups.map((row: InlineNode[][]) => (
                  <tr>
                    {row.map((cell: InlineNode[]) => {
                      const cellHtml = cell.map(renderInlineNode).join('');
                      return <td><Fragment set:html={cellHtml} /></td>;
                    })}
                  </tr>
                ));
              })()}
            </tbody>
          )}
        </table>
      </div>
    );
  }

  if (node.type === 'ordered-list') {
    return (
      <ol class="content-ol">
        {node.items.map((item: ContentNode[]) => (
          <li><Astro.self nodes={item} xrefMap={xrefMap} /></li>
        ))}
      </ol>
    );
  }

  if (node.type === 'unordered-list') {
    return (
      <ul class="content-ul">
        {node.items.map((item: ContentNode[]) => (
          <li><Astro.self nodes={item} xrefMap={xrefMap} /></li>
        ))}
      </ul>
    );
  }

  if (node.type === 'section') {
    if (node.depth === 2) {
      const titleHtml = node.title.map(renderInlineNode).join('');
      return (
        <section class="subsection-block" id={node.id}>
          <h4 class="subsection-heading"><Fragment set:html={titleHtml} /></h4>
          <Astro.self nodes={node.children} xrefMap={xrefMap} />
          {node.subsections.map((sub) => <Astro.self nodes={[sub]} xrefMap={xrefMap} />)}
        </section>
      );
    }
  }

  return null;
})}
