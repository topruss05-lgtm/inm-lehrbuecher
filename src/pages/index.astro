---
import PlatformLayout from '../layouts/PlatformLayout.astro';
import { discoverCourses } from '../lib/xml/course-registry.js';

const courses = discoverCourses();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<PlatformLayout title="INM Lehrbücher">
  <header class="top-bar">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <span class="breadcrumb-home">INM Lehrbücher</span>
    </nav>
    <div class="topbar-actions">
      <button class="topbar-search-trigger" id="open-search" aria-label="Suche öffnen" title="Suche (⌘K)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <kbd class="topbar-kbd">⌘K</kbd>
      </button>
    </div>
  </header>

  <div class="landing-hero">
    <h1 class="landing-title">Institut für Nichtlineare Mechanik</h1>
    <p class="landing-subtitle">Vorlesungsskripte und Lehrmaterialien</p>
  </div>

  <main class="landing-content">
    <div class="course-grid">
      {courses.map((course) => (
        <a href={`${base}/${course.slug}/`} class="course-card">
          <div class="course-card-inner">
            <h2 class="course-card-title">{course.book.title}</h2>
            {course.book.subtitle && (
              <p class="course-card-subtitle">{course.book.subtitle}</p>
            )}
            <p class="course-card-meta">
              {course.book.chapters.filter(c => !c.isAppendix).length} Kapitel
              {course.glossary.length > 0 && ` · ${course.glossary.length} Symbole`}
            </p>
          </div>
          <span class="course-card-arrow">→</span>
        </a>
      ))}
    </div>

    {courses.length === 0 && (
      <p style="text-align: center; color: var(--color-ink-muted); margin-top: 3rem;">
        Noch keine Vorlesungen vorhanden.
      </p>
    )}
  </main>
</PlatformLayout>
