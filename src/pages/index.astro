---
import PlatformLayout from '../layouts/PlatformLayout.astro';
import { discoverCourses } from '../lib/xml/course-registry.js';

const courses = discoverCourses();
---

<PlatformLayout title="INM Lehrbücher">
  <header class="book-header">
    <h1>Institut für Nichtlineare Mechanik</h1>
    <p class="subtitle">Vorlesungsskripte und Lehrmaterialien</p>
  </header>

  <main class="landing-content">
    <div class="course-grid">
      {courses.map((course) => (
        <a href={`/${course.slug}/`} class="course-card">
          <div class="course-card-inner">
            <h2 class="course-card-title">{course.book.title}</h2>
            {course.book.subtitle && (
              <p class="course-card-subtitle">{course.book.subtitle}</p>
            )}
            <p class="course-card-meta">
              {course.book.chapters.filter(c => !c.isAppendix).length} Kapitel
              {course.glossary.length > 0 && ` · ${course.glossary.length} Symbole`}
            </p>
          </div>
          <span class="course-card-arrow">→</span>
        </a>
      ))}
    </div>

    {courses.length === 0 && (
      <p style="text-align: center; color: var(--color-ink-muted); margin-top: 3rem;">
        Noch keine Vorlesungen vorhanden.
      </p>
    )}
  </main>
</PlatformLayout>
